{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ],
  "buildCommand": "echo '使用预构建的静态文件'",
  "outputDirectory": "dist",
  "installCommand": "echo '跳过安装步骤'",
  "env": {
    "NODE_VERSION": "18"
  }
}
