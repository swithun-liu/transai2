selectByBook:
SELECT * FROM translation WHERE bookPath = ?;

selectOne:
SELECT * FROM translation WHERE bookPath = ? AND paragraphId = ?;

insertOrReplace:
INSERT OR REPLACE INTO translation(bookPath, paragraphId, translatedText, isExpanded) VALUES (?, ?, ?, ?);

updateExpansion:
UPDATE translation SET isExpanded = ? WHERE bookPath = ? AND paragraphId = ?;
